ody\" >\n                               \n                                <span class=\"Labelstyle\" [hidden]=\"backupData?.length != 0\">No Data found to display</span>\n                                <div  class=\"PromptDataTableContainer\">\n                                    \n\n                                    <table class=\"PromptDataTableStyle\" [hidden]=\"backupData?.length == 0\" [mfData]=\"data | dataFilter\" #mf=\"mfDataTable\"\n                                           [mfRowsOnPage]=\"rowsOnPage\" [(mfSortBy)]=\"sortBy\" [(mfSortOrder)]=\"sortOrder\">\n                                        <thead>\n                                            <tr>\n                                                <th style=\"width: 10%\"></th>\n\n                                                <th *ngFor=\"let column of columnDefs \" >\n                                                    <mfDefaultSorter by=\"{{column.field}}\">{{column.headerName}}</mfDefaultSorter>\n                                                </th>\n                                            </tr>\n                                            <tr>\n                                                <td align=\"center\"><i class=\"fa fa-search\" aria-hidden=\"true\"></i></td>\n                                                <td *ngFor=\"let column of promptFilter \">\n                                                    <input style=\"width:100%\" *ngIf=\"column.filter\" [(ngModel)]=\"column.searchString\" type=\"text\" (keyup)=\"onKey($event)\"  class=\"Textboxstyle\" >\n                                                </td>\n                                                \n                                            </tr>\n                                        \n                                        </thead>\n                                        <tbody>\n                                            <tr *ngFor=\"let item of mf.data\"  [ngClass]=\"{'selectedRow': item._indexNumber==selectedRowNum}\">\n                                                <td align=\"center\">\n                                                 <input type=\"radio\" name=\"rd\" value=\"item._indexNumber\" (click)=\"selectOne(item)\" [checked]=\"item._indexNumber==selectedRowNum\">\n                                                \n                                                </td>\n\n                                                <td *ngFor=\"let column of columnDefs\">{{item[column.field]}}</td>\n                                            \n                                            </tr>\n                                        </tbody>\n                                        <tfoot>\n                                            <tr>\n                                                <td [colSpan]=\"columnDefs.length+1\">\n                                                    <mfBootstrapPaginator ></mfBootstrapPaginator>\n                                                </td>\n                                            </tr>\n                                        </tfoot>\n                                    </table>\n                                \n                                </div>\n                        </div>\n                        <div class=\"modal-footer\">\n                            <button type=\"button\" class=\"MainButtonStyle\" (click)=\"ok()\" >OK</button>\n                            <button type=\"button\" class=\"MainButtonStyle\" (click)=\"cancel()\" >Cancel</button>\n                        </div>\n            </div>\n\n        </div>\n    </div>\n"}]}],"members":{"id":[{"__symbolic":"property","decorators":[{"__symbolic":"call","expression":{"__symbolic":"reference","module":"@angular/core","name":"Input"}}]}],"taskCode":[{"__symbolic":"property","decorators":[{"__symbolic":"call","expression":{"__symbolic":"reference","module":"@angular/core","name":"Input"}}]}],"onSelect":[{"__symbolic":"property","decorators":[{"__symbolic":"call","expr